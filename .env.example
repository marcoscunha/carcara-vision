# Carcara NVC - Environment Configuration
# Copy this file to .env and modify as needed

# ===================
# Database Configuration
# ===================
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=carcara_nvc
POSTGRES_PORT=5432

# ===================
# Security
# ===================
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Development auth toggle
# false = disable Keycloak auth in backend and frontend for local development
# true = enforce Keycloak login/JWT validation
AUTH_ENABLED=false
VITE_AUTH_ENABLED=false

# Keycloak (OAuth2/OIDC)
# Public URL used by browser redirects and issuer validation
KEYCLOAK_ISSUER_URL=http://localhost:8280
# Internal URL used by backend inside Docker network
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
# Public hostname used by Keycloak itself (set to Jetson IP or DNS in remote access scenarios)
KC_HOSTNAME=localhost

# Frontend build-time Keycloak settings (used by Vite during image build)
VITE_KEYCLOAK_URL=http://localhost:8280
VITE_KEYCLOAK_REALM=carcara
VITE_KEYCLOAK_CLIENT_ID=carcara-frontend

# ===================
# ML Model Configuration
# ===================
# Default model to load on startup
DEFAULT_MODEL=yolov8n.pt

# Detection thresholds
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45
MAX_DETECTIONS=100

# Model storage paths
MODELS_DIR=./models
MODEL_CACHE_DIR=./.model_cache

# ===================
# Hardware Acceleration
# ===================
# Enable GPU acceleration (requires NVIDIA GPU + CUDA)
USE_GPU=false

# Accelerator selection: auto, cpu, cuda, tensorrt, jetson, rpi
ACCELERATOR=auto

# Visible CUDA devices (comma-separated GPU IDs)
# CUDA_VISIBLE_DEVICES=0

# ===================
# TensorRT Configuration (NVIDIA GPUs)
# ===================
TENSORRT_ENABLED=false
TENSORRT_FP16=true
TENSORRT_INT8=false
TENSORRT_WORKSPACE_GB=4

# ===================
# Jetson Configuration
# ===================
# Power mode: 0 = max performance, higher = power saving
JETSON_POWER_MODE=0
# Use DLA cores (Xavier/Orin only)
JETSON_USE_DLA=false

# ===================
# Raspberry Pi Configuration
# ===================
# Enable Coral Edge TPU
RPI_USE_CORAL_TPU=false
# Enable Hailo-8 accelerator
RPI_USE_HAILO=false
# Number of CPU threads (auto-detected if not set)
# RPI_CPU_THREADS=4

# ===================
# Vision Language Model (VLM) Configuration
# ===================
VLM_ENABLED=false
# VLM backend: ollama, openai, local
VLM_BACKEND=ollama
# VLM model name
VLM_MODEL=llava
# Generation settings
VLM_MAX_TOKENS=512
VLM_TEMPERATURE=0.7

# Ollama configuration
OLLAMA_HOST=http://localhost:11434

# OpenAI configuration (uncomment if using OpenAI)
# OPENAI_API_KEY=your-api-key
# OPENAI_MODEL=gpt-4o

# ===================
# Streaming Configuration
# ===================
MAX_CONCURRENT_STREAMS=16
STREAM_BUFFER_SIZE=10
STREAM_RECONNECT_DELAY=5

# Recording settings
RECORDING_ENABLED=false
RECORDING_PATH=./recordings
RECORDING_SEGMENT_DURATION=300

# ===================
# Detection Processing
# ===================
# Process every N frames (1 = all frames)
DETECTION_FRAME_SKIP=1

# Alarm settings
ALARM_COOLDOWN_SECONDS=30
# Classes that trigger alarms
ALARM_CLASSES=person,car,truck

# ===================
# Logging
# ===================
LOG_LEVEL=INFO
# LOG_FILE=/var/log/carcara-nvc/app.log
